    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst secret = $env.WEBHOOK_HMAC_SECRET;\nconst signature = $json.headers['x-signature'];\nconst body = JSON.stringify($json.body);\n\n// Verify HMAC without throwing: a forged/missing signature must return a clean\n// 401 (handled downstream by the Auth OK IF + Respond 401 node) and must NOT\n// route to the error workflow — that would page #autostream-errors on every\n// bad request, a noise/DoS vector once the endpoint is public.\nlet authValid = false;\ntry {\n  if (signature) {\n    const expected = crypto\n      .createHmac('sha256', secret)\n      .update(body)\n      .digest('hex');\n    const sigBuf = Buffer.from(signature, 'hex');\n    const expBuf = Buffer.from(expected, 'hex');\n    if (sigBuf.length === expBuf.length && crypto.timingSafeEqual(sigBuf, expBuf)) {\n      authValid = true;\n    }\n  }\n} catch (e) {\n  authValid = false;\n}\n\nreturn { ...$json.body, _authValid: authValid, _ts_start: Date.now() };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        0
      ],
      "id": "645b8166-6c1c-4a1e-9d00-5e8b8d9e6197",
      "name": "Verify HMAC"
    },
