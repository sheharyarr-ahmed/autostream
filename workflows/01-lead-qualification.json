            {
              "id": "a1f0c2e4-7b3d-4c9a-8e21-1f2a3b4c5d6e",
              "leftValue": "={{ $json._authValid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
