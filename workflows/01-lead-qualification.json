              "name": "max_tokens",
              "value": "={{ 512 }}"
            },
            {
              "name": "system",
              "value": "You are a B2B-SaaS lead qualifier. Score the inbound lead 0-100 on fit, intent, and urgency.  Return ONLY a valid JSON object. No markdown. No explanation. No code fences. No preamble. Just raw JSON.  The JSON must have this exact structure: {\"score\": <number 0-100>, \"fit\": \"low\"|\"medium\"|\"high\", \"intent\": \"research\"|\"evaluate\"|\"buy\", \"urgency\": \"low\"|\"medium\"|\"high\", \"reasoning\": \"<one sentence>\"}  CRITICAL: Your entire response must be parseable by JSON.parse(). Do not include backticks, headers, tables, or any text outside the JSON object. Start with { and end with }."
            },
            {
              "name": "messages",
              "value": "={{[{role: \"user\", content: JSON.stringify($json)}]}}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
