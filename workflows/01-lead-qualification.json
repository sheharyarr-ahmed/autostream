      "id": "b0de3cec-68fb-4733-bfce-5b07b10eb399",
      "name": "Anthropic — Score Lead",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 1000
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst text = response.content?.[0]?.text || '';\n\n// Strip markdown code fences if present\nlet cleaned = text.replace(/^```(?:json)?\\s*/i, '').replace(/```\\s*$/, '').trim();\n\n// Extract JSON object from anywhere in the response (resilient to extra markdown)\nconst jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\nif (jsonMatch) {\n  cleaned = jsonMatch[0];\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('Non-JSON from Claude: ' + text.slice(0, 200));\n}\n\nif (typeof parsed.score !== 'number') throw new Error('Missing or invalid score field');\nif (!['low','medium','high'].includes(parsed.fit)) throw new Error('Invalid fit value: ' + parsed.fit);\nif (!['research','evaluate','buy'].includes(parsed.intent)) throw new Error('Invalid intent value: ' + parsed.intent);\nif (!['low','medium','high'].includes(parsed.urgency)) throw new Error('Invalid urgency value: ' + parsed.urgency);\n\nreturn { parsed: parsed, raw_response: response, model: response.model, usage: response.usage };"
      },
