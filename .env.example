# =============================================================================
# AutoStream — environment template
# Copy to .env and fill in. NEVER commit .env. Run scripts/preflight-checks.sh
# after filling to validate keys + connectivity.
# =============================================================================

# --- n8n core ----------------------------------------------------------------
# Must be >= 32 chars. Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Basic auth for n8n UI (http://localhost:5678)
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Optional — public host config (defaults to localhost)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- Internal Postgres (n8n's own state) -------------------------------------
POSTGRES_USER=n8n
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (observability — separate from n8n's internal Postgres) --------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Slack -------------------------------------------------------------------
# Default channel (lead alerts → #autostream-alerts, errors → #autostream-errors)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Per-category incoming webhooks for email classification (workflow 3).
# Each maps a classified category to its own channel. For a single-channel
# demo you may point all five at the same URL as SLACK_WEBHOOK_URL above.
SLACK_WEBHOOK_SALES=https://hooks.slack.com/services/...
SLACK_WEBHOOK_SUPPORT=https://hooks.slack.com/services/...
SLACK_WEBHOOK_RECRUITING=https://hooks.slack.com/services/...
SLACK_WEBHOOK_BILLING=https://hooks.slack.com/services/...
SLACK_WEBHOOK_OTHER=https://hooks.slack.com/services/...

# --- Webhook signing ---------------------------------------------------------
# HMAC-SHA256 secret for verifying inbound /webhook/lead payloads
WEBHOOK_HMAC_SECRET=

# --- IMAP (email classification workflow) ------------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# --- RSS feeds (daily content brief) -----------------------------------------
# Comma-separated list of feed URLs
RSS_FEEDS=

# --- Timezone (controls cron in workflow 2) ----------------------------------
TIMEZONE=Asia/Karachi
